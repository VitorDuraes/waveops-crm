# WaveOps CRM — variaveis de ambiente (exemplo).
# Copie para .env.local e preencha. NUNCA commite valores reais.
# Stack: PostgreSQL em Docker + auth propria (jose + bcrypt) + Drizzle.

# Banco PostgreSQL (server-only, NUNCA prefixar com NEXT_PUBLIC).
# Dev: o banco roda no Docker (docker-compose.dev.yml) com a porta 5434 publicada no host.
DATABASE_URL=postgres://waveops:troque_esta_senha@localhost:5434/waveops_crm

# DIRECT_URL (PROD): conexao DIRETA ao Postgres (porta 5432), usada SO pelas migrations.
# Em prod com pooler (Supabase/Neon, porta 6543 em transaction mode) o pooler nao migra.
# Defina DIRECT_URL com a conexao direta. Local: o drizzle-kit cai em DATABASE_URL.
# DIRECT_URL=postgres://USUARIO:SENHA@HOST:5432/waveops_crm

# Segredo do cookie de sessao (JWT HS256). 32+ bytes. Gere com: openssl rand -base64 48
SESSION_SECRET=

# App
APP_URL=http://localhost:3000

# Token que o WaveOps Prospect usa para mandar lead na API de ingestao (POST /api/ingest/lead).
# Bearer no header Authorization. Server-only (NUNCA NEXT_PUBLIC). Gere com: openssl rand -base64 32
CRM_INGEST_TOKEN=

# --- Railway (producao) ---
# DATABASE_URL: referencie o Postgres do projeto -> DATABASE_URL=${{Postgres.DATABASE_URL}}
#   (conexao DIRETA; NAO precisa de DIRECT_URL, o migrate usa DATABASE_URL).
# HOSTNAME=0.0.0.0  (o Next escuta na PORT injetada pelo Railway).
# SESSION_SECRET e CRM_INGEST_TOKEN: gere novos (nao reuse os de dev).
# Migrations rodam sozinhas no deploy (railway.json -> preDeployCommand: node scripts/migrate.mjs).
